# =============================================
# CRASH-BOT Configuración
# =============================================
# Copia este archivo como .env y reemplaza los valores de ejemplo.
# cp .env.example .env

# Telegram – copia el token que te dio @BotFather
# Habla con @BotFather en Telegram para crear tu bot y obtener el token.
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ID del chat donde el bot envía notificaciones
# Envía /start a tu bot y luego visita:
# https://api.telegram.org/bot<TU_TOKEN>/getUpdates
# Busca "chat":{"id": ...} en la respuesta JSON
TELEGRAM_CHAT_ID=your_chat_id_here

# Binance API (solo necesario para server.js / trading real)
# Crea tus API keys en: https://www.binance.com/en/my/settings/api-management
# IMPORTANTE: Activa los permisos de trading en tu API key
API_KEY=your_binance_api_key_here
API_SECRET=your_binance_api_secret_here
