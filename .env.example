# ─────────────────────────────────────────────────────────────────────────────
# CRASH-BOT Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=

# Chat ID where signals are sent (use @userinfobot or getUpdates to find it)
# Start a conversation with your bot and visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id": ...} in the JSON response
TELEGRAM_CHAT_ID=

# ── Binance (optional – only needed for live trading) ─────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Legacy aliases (used by server.js / older configs)
API_KEY=
API_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to the project root or absolute)
DATABASE_URL=./data/crash-bot.db

# ── Application ───────────────────────────────────────────────────────────────
# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Runtime environment: development | production
NODE_ENV=production

# Port for the /health check HTTP endpoint
PORT=3000

# ── Bot Tuning (optional) ─────────────────────────────────────────────────────
# Interval between rounds in milliseconds (default: 5000)
# BOT_INTERVAL_MS=5000

# Minimum time between Telegram messages in milliseconds (default: 4000)
# INTERVALO_MIN_MS=4000

# Maximum number of rounds to keep in memory (default: 200)
# MAX_HISTORIAL=200

# ── Base44 API ────────────────────────────────────────────────────────────────
BASE44_APP_ID=69e61353638c587ba182d5e6
BASE44_API_KEY=1dc03497663f4ab2bc84e5cf3fc796cd
BASE44_BASE_URL=https://quizzical-find-zen-flow.base44.app/api
