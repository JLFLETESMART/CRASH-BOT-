# ─────────────────────────────────────────────────────────────────────────────
# CRASH-BOT Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=

# Chat ID where signals are sent (use @userinfobot or getUpdates to find it)
TELEGRAM_CHAT_ID=

# ── Binance (optional – only needed for live trading via server.js) ────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to the project root or absolute)
DATABASE_URL=./data/crash-bot.db

# ── Application ───────────────────────────────────────────────────────────────
# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Runtime environment: development | production
NODE_ENV=production

# Port for the /health check HTTP endpoint
PORT=3000

# ── Bot Tuning (optional) ─────────────────────────────────────────────────────
# Interval between rounds in milliseconds (default: 5000)
# BOT_INTERVAL_MS=5000

# Minimum time between Telegram messages in milliseconds (default: 4000)
# INTERVALO_MIN_MS=4000

# Maximum number of rounds to keep in memory (default: 200)
# MAX_HISTORIAL=200
